{
  "name": "iot-commander",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "terraform-deploy": "wrangler deploy --dry-run --outdir build && cd terraform && terraform apply",
    "init-db:local": "wrangler d1 execute D1_DB --local --file=./migrations/init.sql",
    "init-db:remote": "wrangler d1 execute D1_DB --remote --file=./migrations/init.sql",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@types/node": "^25.4.0",
    "typescript": "^5.5.2",
    "vitest": "~3.2.0",
    "wrangler": "^4.72.0"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.2",
    "@scalar/hono-api-reference": "^0.10.2",
    "@types/web-push": "^3.6.4",
    "hono": "^4.12.7",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  }
}
