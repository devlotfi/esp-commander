    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.5.2",
    "vitest": "~3.2.0",
    "wrangler": "^4.72.0"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.2",
    "@scalar/hono-api-reference": "^0.10.2",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  }
}
